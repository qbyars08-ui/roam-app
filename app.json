{
  "expo": {
    "name": "ROAM",
    "slug": "roam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "roam",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.roam.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "associatedDomains": ["applinks:roamtravel.app"],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "ROAM uses your location to show nearby events, weather, and safety information for your destination.",
        "NSMicrophoneUsageDescription": "ROAM uses your microphone for voice input when planning trips and chatting with the AI travel assistant.",
        "NSPhotoLibraryUsageDescription": "ROAM accesses your photos to set trip cover images and share trip cards.",
        "NSSpeechRecognitionUsageDescription": "ROAM uses speech recognition for hands-free trip planning and voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0D1F1A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-router", { "asyncRoutes": { "web": true } }],
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-speech-recognition",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0D1F1A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c19740b8-17b5-43c6-8156-35bacc2312dd"
      }
    },
    "owner": "quinnbyra"
  }
}
