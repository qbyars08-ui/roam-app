# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://byetqukwnanrmupovzev.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_claude_key
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# RevenueCat — Sign up at https://app.revenuecat.com
# Create iOS and Android apps, add monthly + annual products, entitlement "pro"
# Pro Monthly: $9.99/month
# Global Pass Annual: $49.99/year
REVENUECAT_API_KEY=your_revenuecat_key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Investor dashboard — comma-separated emails allowed to view /investor
EXPO_PUBLIC_INVESTOR_EMAILS=

# Optional APIs (client-side = EXPO_PUBLIC_* in this file; server-side = Supabase secrets)
EXPO_PUBLIC_AVIATIONSTACK_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
EXPO_PUBLIC_EXCHANGERATE_KEY=
EXPO_PUBLIC_OPENWEATHER_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
EXPO_PUBLIC_EVENTBRITE_TOKEN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_TICKETMASTER_KEY=
EXPO_PUBLIC_UNSPLASH_ACCESS_KEY=

# Supabase secrets (set via: supabase secrets set NAME=value from roam/)
# Server-side only — do not put in .env or client code.
#   GOOGLE_PLACES_KEY or GOOGLE_API_KEY  — places-proxy, destination-photo, enrich-venues
#   ELEVENLABS_API_KEY                    — voice-proxy
#   OPENWEATHERMAP_KEY                    — weather-intel
#   EVENTBRITE_API_KEY                    — travel-proxy
#   PERPLEXITY_API_KEY                    — sonar-proxy (already set)
#   FOURSQUARE_API_KEY                    — travel-proxy (already set)
#   TRIPADVISOR_API_KEY                   — travel-proxy (already set)
#   MAPBOX_API_KEY                        — any edge function using Mapbox (same value as EXPO_PUBLIC_MAPBOX_TOKEN)
