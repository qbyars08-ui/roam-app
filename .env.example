# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://byetqukwnanrmupovzev.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_claude_key
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# RevenueCat — Sign up at https://app.revenuecat.com
# Create iOS and Android apps, add monthly + annual products, entitlement "pro"
# Pro Monthly: $9.99/month
# Global Pass Annual: $49.99/year
REVENUECAT_API_KEY=your_revenuecat_key
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Investor dashboard — comma-separated emails allowed to view /investor
EXPO_PUBLIC_INVESTOR_EMAILS=

# Optional APIs
EXPO_PUBLIC_AVIATIONSTACK_KEY=
EXPO_PUBLIC_GOOGLE_PLACES_KEY=
EXPO_PUBLIC_EXCHANGERATE_KEY=
EXPO_PUBLIC_OPENWEATHER_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=

# Image CDN — Cloudinary Fetch mode (free tier: 25GB/mo, ~312K serves)
# Sign up at cloudinary.com (free, no credit card). Get cloud name from dashboard.
# Wraps all images.unsplash.com URLs through Cloudinary CDN for reliability + WebP.
# Leave blank to serve Unsplash URLs directly (works fine, no CDN layer).
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=
