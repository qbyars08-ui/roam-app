{
  "name": "roam",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "pre-push": "tsc --noEmit && npx expo export --platform web",
    "profile": "expo start --dev-client",
    "start": "expo start",
    "build:web": "npx expo export --platform web && echo '/*  /index.html  200' > dist/_redirects",
    "export:web": "npx expo export --platform web",
    "inject-outputs": "node scripts/inject-outputs.js",
    "deploy:web": "npm run build:web && netlify deploy --prod --dir=dist",
    "start:lan": "expo start",
    "start:tunnel": "expo start --tunnel",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --port 3000",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@expo-google-fonts/cormorant-garamond": "^0.4.1",
    "@expo-google-fonts/dm-mono": "^0.4.2",
